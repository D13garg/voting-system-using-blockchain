# --- Dependencies ---
node_modules/

# --- Env files (never commit real secrets/keys) ---
.env
.env.local
.env.*.local
!.env.example

# --- Build output ---
backend/dist/
frontend/dist/
*.tsbuildinfo

# --- Hardhat (contracts/) ---
contracts/artifacts/
contracts/cache/
contracts/coverage/
contracts/coverage.json
contracts/typechain-types/

# Generated by `hardhat compile`'s typechain step (see hardhat.config.ts's
# typechain.outDir) - regenerate locally with `pnpm --filter @dvs/contracts
# compile`. shared/abi/*.json (the extracted ABI, see extract-abi.ts) IS
# committed - only the generated TS types are ignored here.
shared/abi/typechain-types/

# Deploy output - re-generated by scripts/deploy.ts on every local deploy
# (see contractAddresses.ts). If you want to permanently track a real
# Sepolia deployment's addresses, copy them elsewhere or remove this line.
shared/contract-addresses.json

# --- Test / coverage artifacts ---
coverage/
.nyc_output/

# --- Logs ---
*.log
npm-debug.log*
pnpm-debug.log*

# --- Editor / OS noise ---
.DS_Store
Thumbs.db
.vscode/*
!.vscode/extensions.json
.idea/

# --- Vite (frontend/) ---
frontend/.vite/