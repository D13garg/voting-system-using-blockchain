# Copy this file to .env.local and fill in real values (Vite loads
# .env.local automatically; never commit .env.local itself).
# Every var here MUST be prefixed VITE_ — Vite only exposes prefixed vars
# to client code (see wagmiConfig.ts / apiClient.ts for how each is read).

# Backend API base URL. Points at the local API process (backend/src/app.ts,
# API_PORT default 4000) in dev; the deployed API service's URL elsewhere.
VITE_API_BASE_URL=http://localhost:4000

# WalletConnect Cloud project ID (required for RainbowKit's
# WalletConnect/mobile-wallet connector). Get one free at
# https://cloud.walletconnect.com — without it, injected wallets
# (MetaMask browser extension) still work, but WalletConnect/mobile
# options in the connect modal will not.
VITE_WALLETCONNECT_PROJECT_ID=your-walletconnect-cloud-project-id
