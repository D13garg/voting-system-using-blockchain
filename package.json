{
  "name": "decentralized-voting-system",
  "private": true,
  "version": "0.1.0",
  "description": "Production-inspired decentralized voting platform. Architecture v3.0 — see docs/architecture/architecture.md and docs/architecture/ADR/.",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "./dev.sh",
    "dev:down": "docker compose -f docker-compose.yml -f docker-compose.dev.yml down",
    "dev:reset": "docker compose -f docker-compose.yml -f docker-compose.dev.yml down -v",
    "lint": "pnpm -r lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "pnpm -r test"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "eslint": "^9.9.1",
    "prettier": "^3.3.3",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.3.0"
  },
  "dependencies": {
    "pnpm": "^11.11.0"
  }
}