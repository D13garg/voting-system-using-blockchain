{
  "name": "@dvs/contracts",
  "version": "0.1.0",
  "private": true,
  "description": "Smart contracts for the Decentralized Voting System (VoterRegistry, Election). See docs/architecture/ADR/ADR-005.",
  "license": "MIT",
  "scripts": {
    "compile": "hardhat compile",
    "postcompile": "ts-node scripts/extract-abi.ts",
    "extract-abi": "ts-node scripts/extract-abi.ts",
    "test": "hardhat test",
    "coverage": "hardhat coverage",
    "node": "hardhat node",
    "deploy:local": "hardhat run scripts/deploy.ts --network localhost",
    "deploy:sepolia": "hardhat run scripts/deploy.ts --network sepolia",
    "verify:sepolia": "hardhat run scripts/verify.ts --network sepolia",
    "lint": "eslint . && solhint 'contracts/**/*.sol'",
    "lint:ts": "eslint .",
    "lint:sol": "solhint 'contracts/**/*.sol'",
    "clean": "hardhat clean"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.0.8",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@nomicfoundation/hardhat-verify": "^2.0.10",
    "@openzeppelin/contracts": "^5.0.2",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.1.0",
    "@types/node": "^20.14.15",
    "chai": "^4.4.1",
    "dotenv": "^16.4.5",
    "eslint": "^9.9.1",
    "globals": "^15.9.0",
    "hardhat": "^2.22.6",
    "mocha": "^10.7.3",
    "solc": "0.8.24",
    "solhint": "^6.0.0",
    "solidity-coverage": "^0.8.12",
    "ts-node": "^10.9.2",
    "typechain": "^8.3.2",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.3.0"
  }
}
