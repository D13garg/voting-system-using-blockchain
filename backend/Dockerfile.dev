# Local-dev-only image, shared by both the `api` and `worker` services in
# docker-compose.dev.yml - differing only by CMD (dev:api vs dev:worker),
# same rationale Dockerfile.api's header comment already gives for why
# the *production* images are split by CMD, not by separate Dockerfiles.
#
# Differs from the production Dockerfile.api/worker in two ways:
#  1. Built from the REPO ROOT, not ./backend - see contracts/Dockerfile.dev's
#     header comment for why (real pnpm workspace, one root lockfile).
#  2. Runs `tsx watch` directly against source (bind-mounted at runtime by
#     docker-compose.dev.yml) instead of a compiled dist/ build, so code
#     edits on the host hot-reload the running container the same way
#     `pnpm --filter @dvs/backend dev:api` already does outside Docker -
#     there is no reason local iteration should be slower just because
#     it's containerized.
FROM node:22-alpine
WORKDIR /app
RUN corepack enable

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY backend/package.json backend/package.json
COPY contracts/package.json contracts/package.json
COPY frontend/package.json frontend/package.json
RUN pnpm install --frozen-lockfile --filter @dvs/backend...

COPY backend backend

WORKDIR /app/backend
RUN chmod +x docker/wait-for-contracts.sh

EXPOSE 4000
ENTRYPOINT ["docker/wait-for-contracts.sh"]
CMD ["pnpm", "run", "dev:api"]
