{
  "name": "@dvs/backend",
  "version": "0.1.0",
  "private": true,
  "description": "API and worker processes for the Decentralized Voting System. Two entrypoints, one codebase — see docs/architecture/ADR/ADR-002.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev:api": "tsx watch src/app.ts",
    "dev:worker": "tsx watch worker/worker.ts",
    "build": "tsc -p tsconfig.json",
    "start:api": "node dist/app.js",
    "start:worker": "node dist/worker/worker.js",
    "lint": "eslint .",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts"
  },
  "dependencies": {
    "bullmq": "^5.12.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "mongoose": "^8.5.2",
    "multer": "^1.4.5-lts.1",
    "pino": "^9.3.2",
    "pino-http": "^10.2.0",
    "rate-limiter-flexible": "^11.2.0",
    "react": "^18.3.1",
    "siwe": "^2.3.2",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "viem": "^2.18.6",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.14.15",
    "@types/supertest": "^7.2.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.6",
    "eslint": "^9.9.1",
    "globals": "^15.9.0",
    "mongodb-memory-server": "^10.0.0",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.2.2",
    "tsx": "^4.16.5",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.3.0",
    "vitest": "^2.1.9"
  }
}