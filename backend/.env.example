# Copy this file to .env and fill in real values. Never commit .env itself.
# Every variable here is validated at process startup by src/config/env.ts —
# if one is missing or malformed, both the API and worker processes will
# refuse to start, with a clear error naming the problem.

NODE_ENV=development

# --- Blockchain ---:
RPC_URL_PRIMARY=https://eth-sepolia.g.alchemy.com/v2/your-alchemy-key
RPC_URL_FALLBACK=https://sepolia.infura.io/v3/your-infura-key
CHAIN_ID=11155111
CONTRACT_ADDRESS_VOTER_REGISTRY=0x0000000000000000000000000000000000000000
CONTRACT_ADDRESS_ELECTION=0x0000000000000000000000000000000000000000
# Optional: only needed for the rare backend-initiated read/estimation calls.
# Never the same key as the contract deployer or any admin wallet (ADR-004).
BACKEND_SIGNER_PRIVATE_KEY=

# --- MongoDB ---
MONGODB_URI=mongodb://localhost:27017/decentralized-voting-system
MONGODB_MAX_POOL_SIZE=10

# --- Redis / BullMQ ---
REDIS_URL=redis://localhost:6379

# --- IPFS ---
IPFS_API_KEY=your-web3-storage-or-pinata-key
IPFS_API_SECRET=your-web3-storage-or-pinata-secret
IPFS_GATEWAY_URL=https://w3s.link

# --- Auth (SIWE) ---
SIWE_DOMAIN=localhost:5173
SIWE_SESSION_SECRET=replace-with-a-real-32-plus-character-random-secret
SIWE_SESSION_TTL_SECONDS=86400

# --- Monitoring (optional in local dev) ---
SENTRY_DSN=
TENDERLY_PROJECT_SLUG=

# --- Process ---
API_PORT=4000
LOG_LEVEL=debug
